ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/cuda-11.8/bin/nvcc

cflags = -Wno-unused-result -Wsign-compare -DNDEBUG -g -fwrapv -O2 -Wall -g -fstack-protector-strong -Wformat -Werror=format-security -g -fwrapv -O2 -g -fstack-protector-strong -Wformat -Werror=format-security -Wdate-time -D_FORTIFY_SOURCE=2 -fPIC -I/data1/ldy/llm_quant_infer/lib/python3.10/site-packages/torch/include -I/data1/ldy/llm_quant_infer/lib/python3.10/site-packages/torch/include/torch/csrc/api/include -I/data1/ldy/llm_quant_infer/lib/python3.10/site-packages/torch/include/TH -I/data1/ldy/llm_quant_infer/lib/python3.10/site-packages/torch/include/THC -I/usr/local/cuda-11.8/include -I/data1/ldy/llm_quant_infer/include -I/usr/include/python3.10 -c
post_cflags = -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=quant_cuda -D_GLIBCXX_USE_CXX11_ABI=0 -std=c++17
cuda_cflags = -I/data1/ldy/llm_quant_infer/lib/python3.10/site-packages/torch/include -I/data1/ldy/llm_quant_infer/lib/python3.10/site-packages/torch/include/torch/csrc/api/include -I/data1/ldy/llm_quant_infer/lib/python3.10/site-packages/torch/include/TH -I/data1/ldy/llm_quant_infer/lib/python3.10/site-packages/torch/include/THC -I/usr/local/cuda-11.8/include -I/data1/ldy/llm_quant_infer/include -I/usr/include/python3.10 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=quant_cuda -D_GLIBCXX_USE_CXX11_ABI=0 -gencode=arch=compute_86,code=compute_86 -gencode=arch=compute_86,code=sm_86 -std=c++17
cuda_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc  $cuda_cflags -c $in -o $out $cuda_post_cflags





build /data1/ldy/llm_quant_infer/lib/kvquant/deployment/kvquant/build/temp.linux-x86_64-3.10/quant_cuda.o: compile /data1/ldy/llm_quant_infer/lib/kvquant/deployment/kvquant/quant_cuda.cpp
build /data1/ldy/llm_quant_infer/lib/kvquant/deployment/kvquant/build/temp.linux-x86_64-3.10/quant_cuda_kernel.o: cuda_compile /data1/ldy/llm_quant_infer/lib/kvquant/deployment/kvquant/quant_cuda_kernel.cu






